# LLM Provider: 'ollama' or 'gemini'
LLM_PROVIDER=gemini

# Model name
# For Gemini: gemini-2.0-flash OR gemini-2.5-pro
# For Ollama: gemma3:4b OR gemma3:12b
DEFAULT_MODEL=gemini-2.0-flash

# Required only if LLM_PROVIDER=gemini
# Get your free key at: https://aistudio.google.com/api-keys
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Increases GitHub API rate limits
# GITHUB_TOKEN=your_github_token_here
